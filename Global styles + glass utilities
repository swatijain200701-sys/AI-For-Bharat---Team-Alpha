@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body {
    @apply bg-background text-foreground;
    font-feature-settings: "rlig" 1, "calt" 1;
  }
}

@layer utilities {
  .glass {
    @apply bg-card backdrop-blur-md border border-white/10 shadow-glass;
  }
  
  .glass-hover {
    @apply hover:bg-card/80 hover:border-white/20 hover:shadow-glass-hover transition-all duration-300;
  }
  
  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-primary to-blue-400;
  }
}
