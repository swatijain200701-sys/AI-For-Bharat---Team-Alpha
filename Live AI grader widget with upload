"use client";

import { useState, useEffect } from "react";
import { Search, Filter, Bookmark, MapPin, Building, Calendar, Check, ExternalLink } from "lucide-react";
import { Button } from "@/components/ui/Button";

type Opp = {
    title: string;
    org: string;
    type: string;
    amount: string;
    location: string;
    deadline: string;
    match: string;
    url?: string;
};

export default function ExploreOpportunities() {
    const [opps, setOpps] = useState<Opp[]>([
        {
            title: "Google AI Impact Grant",
            org: "Google.org",
            type: "Grant",
            amount: "Up to $50,000",
            location: "Remote / India",
            deadline: "Oct 15, 2024",
            match: "92%",
            url: "https://www.google.org/"
        },
        {
            title: "AWS AI Startup Fellowship",
            org: "Amazon Web Services",
            type: "Fellowship",
            amount: "Credits + Mentorship",
            location: "Remote",
            deadline: "Closing Soon",
            match: "75%",
            url: "https://aws.amazon.com/startups/"
        }
    ]);

    // Fetch live Hackathons from our API route
    useEffect(() => {
        const fetchHackathons = async () => {
            try {
                const response = await fetch('/api/hackathons');
                if (!response.ok) throw new Error("Failed to fetch");

                const liveHackathons: Opp[] = await response.json();

                // Add live hackathons to the state (avoiding duplicates if it remounts on Dev)
                setOpps(prev => {
                    const existingTitles = new Set(prev.map(o => o.title));
                    const uniqueNew = liveHackathons.filter(h => !existingTitles.has(h.title));
                    return [...prev, ...uniqueNew];
                });
            } catch (e) {
                console.error("Failed to load live hackathons", e);
            }
        };
        fetchHackathons();
    }, []);

    const [savedOpps, setSavedOpps] = useState<string[]>([]);
    const [appliedOpps, setAppliedOpps] = useState<string[]>([]);
    const [activeCategory, setActiveCategory] = useState<string>("All");
    const [mounted, setMounted] = useState(false);

    useEffect(() => {
        setMounted(true);
        const saved = JSON.parse(localStorage.getItem("ai_opphub_saved") || "[]").map((o: Opp) => o.title);
        setSavedOpps(saved);
        const applied = JSON.parse(localStorage.getItem("ai_opphub_applied") || "[]");
        setAppliedOpps(applied);
    }, []);

    const filteredOpps = activeCategory === "All"
        ? opps
        : opps.filter(opp => opp.type === activeCategory);

    const toggleSave = (opp: Opp) => {
        const currentSaved = JSON.parse(localStorage.getItem("ai_opphub_saved") || "[]");
        const isSaved = currentSaved.some((o: Opp) => o.title === opp.title);

        let newSaved;
        if (isSaved) {
            newSaved = currentSaved.filter((o: Opp) => o.title !== opp.title);
            setSavedOpps(savedOpps.filter(t => t !== opp.title));
        } else {
            newSaved = [...currentSaved, opp];
            setSavedOpps([...savedOpps, opp.title]);
        }
        localStorage.setItem("ai_opphub_saved", JSON.stringify(newSaved));
    };

    const handleApply = (opp: Opp) => {
        if (!appliedOpps.includes(opp.title)) {
            const newApplied = [...appliedOpps, opp.title];
            setAppliedOpps(newApplied);
            localStorage.setItem("ai_opphub_applied", JSON.stringify(newApplied));

            // To simulate applying or linking out:
            // window.open('https://example.com/apply', '_blank');
        }
    };

    if (!mounted) return null; // Prevent hydration mismatch

    return (
        <div className="space-y-6 animate-in fade-in duration-500">
            <div className="flex flex-col md:flex-row gap-4 items-center justify-between mb-8">
                <h1 className="text-2xl font-bold">Explore Opportunities</h1>
                <div className="flex w-full md:w-auto gap-3">
                    <div className="relative flex-1 md:w-64">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-foreground/50" />
                        <input
                            type="text"
                            placeholder="Search hackathons, grants..."
                            className="w-full h-10 pl-9 pr-4 rounded-lg bg-white/5 border border-white/10 text-sm focus:outline-none focus:border-primary/50"
                        />
                    </div>
                    <Button variant="outline" className="shrink-0 gap-2">
                        <Filter className="h-4 w-4" /> Filters
                    </Button>
                </div>
            </div>

            <div className="flex gap-2 mb-6 overflow-x-auto pb-2 scrollbar-hide">
                <Button size="sm" variant={activeCategory === "All" ? "default" : "ghost"} className={`rounded-full ${activeCategory !== "All" && "bg-white/5"}`} onClick={() => setActiveCategory("All")}>For You (AI Matches)</Button>
                <Button size="sm" variant={activeCategory === "Hackathon" ? "default" : "ghost"} className={`rounded-full ${activeCategory !== "Hackathon" && "bg-white/5"}`} onClick={() => setActiveCategory("Hackathon")}>Hackathons</Button>
                <Button size="sm" variant={activeCategory === "Grant" ? "default" : "ghost"} className={`rounded-full ${activeCategory !== "Grant" && "bg-white/5"}`} onClick={() => setActiveCategory("Grant")}>Grants</Button>
                <Button size="sm" variant={activeCategory === "Fellowship" ? "default" : "ghost"} className={`rounded-full ${activeCategory !== "Fellowship" && "bg-white/5"}`} onClick={() => setActiveCategory("Fellowship")}>Fellowships</Button>
            </div>

            <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {filteredOpps.map((opp, idx) => {
                    const isSaved = savedOpps.includes(opp.title);
                    const isApplied = appliedOpps.includes(opp.title);

                    return (
                        <div key={idx} className={`glass rounded-xl overflow-hidden transition-all duration-300 group flex flex-col h-full ${isSaved ? 'border-primary/40' : 'hover:border-primary/30'}`}>
                            <div className="p-5 flex-1 border-b border-white/5 relative">
                                {isApplied && (
                                    <div className="absolute top-2 right-2 rotate-12 text-green-500 font-bold border-2 border-green-500 px-2 rounded tracking-widest bg-background/80 text-xs backdrop-blur-sm z-10">
                                        APPLIED
                                    </div>
                                )}
                                <div className="flex justify-between items-start mb-4">
                                    <span className="text-xs font-bold px-2 py-1 rounded bg-primary/10 text-primary uppercase tracking-wider">
                                        {opp.type}
                                    </span>
                                    <span className="text-xs font-semibold text-green-400 bg-green-400/10 px-2 py-1 rounded-full">
                                        {opp.match} Match
                                    </span>
                                </div>

                                <h3 className="font-bold text-lg mb-2 leading-tight group-hover:text-primary transition-colors">{opp.title}</h3>

                                <div className="space-y-2 mt-4 text-sm text-foreground/70">
                                    <div className="flex items-center gap-2"><Building className="h-4 w-4" /> {opp.org}</div>
                                    <div className="flex items-center gap-2"><MapPin className="h-4 w-4" /> {opp.location}</div>
                                    <div className="flex items-center gap-2"><Calendar className="h-4 w-4" /> {opp.deadline}</div>
                                </div>

                                <div className="mt-4 pt-4 border-t border-white/5 font-semibold text-foreground/90">
                                    {opp.amount}
                                </div>
                            </div>

                            <div className="p-4 bg-black/20 flex gap-3">
                                {isApplied ? (
                                    <Button className="flex-1 bg-green-500 hover:bg-green-600 text-white gap-2 cursor-pointer" onClick={() => window.open(opp.url || '#', '_blank')}>
                                        <Check className="h-4 w-4" /> View Details
                                    </Button>
                                ) : (
                                    <Button className="flex-1 gap-2" onClick={() => handleApply(opp)}>
                                        <ExternalLink className="h-4 w-4" /> Apply Now
                                    </Button>
                                )}
                                <Button
                                    variant={isSaved ? "default" : "outline"}
                                    size="icon"
                                    className={`shrink-0 ${isSaved ? 'bg-primary/20 text-primary hover:bg-primary/30 border-primary/50' : ''}`}
                                    onClick={() => toggleSave(opp)}
                                >
                                    <Bookmark className={`h-4 w-4 ${isSaved ? 'fill-primary' : ''}`} />
                                </Button>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    );
}
